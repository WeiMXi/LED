%!GLoBES
$version="3.2.13"


/*************************************************
**************************************************
*** Prepared by Pedro Pasquini(03 March 2020)  ***
***   https://inspirehep.net/authors/1467863   ***
***              T2K-CURRENT                   ***  
*** see ref: 1805.05917 and 1807.07891         ***
***          nue->nue and anue->anue           ***
*** 		   flux from 		       ***
***   http://cds.cern.ch/record/2695231/plots  ***
**************************************************
**************************************************/

nuflux(#T2Kplus)
<
	@flux_file = "../experiments/prob test/flux/T2K_LHC_mode_2018_flux.dat"
	@time = 12.0
	@power = 0.75 /* MW */
	@norm = 0.033358 /* for 14.9x10^20 POT*/
>
//Flux part is not corresponding to new data

$profiletype = 3
$densitytab = {2.8}
$lengthtab = {810}


$target_mass = 22.5 /* kt */



$emin =  0.2
$emax =  2.0
$bins = 200

 
$sampling_points = 200 
$sampling_min = 0.1
$sampling_max = 3.0



$filter_state = 1
$filter_value = 0.1


cross(#QE) < @cross_file = "../experiments/prob test/xsec/waterGENIE3_CCQE.dat" >
cross(#NC) < @cross_file = "../experiments/prob test/xsec/waterGENIE3_NC.dat" >


energy(#CCQE_numu)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>

energy(#CCQE_numu_MIS)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>

energy(#NC_numu)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>



/***********************************************
************************************************
***                                          ***
***               NU MODE                    ***
***                                          ***
************************************************
**********************************************/


auxFactor = 1.2
/* SIGNAL DECLARATION */
channel(#v_m_to_v_m) 
< 
	@channel =   #T2Kplus:	  +:	 mu:	 mu:	#QE:	 #CCQE_numu

//	@post_smearing_efficiencies = {0.0094968691,1.9466575410,4.9432322670,5.8380698493,6.0161428314,
//	5.8083387895,5.2768768811,5.2812953595,5.7815505398,6.5586505483,
//	6.7502855019,6.4756534604,6.0451506694,5.5760796359,5.4578685899,
//	5.1706974975,5.0844496066,5.2217968968,5.2919684886,5.4121266425,
//	5.5306225782,5.5580631902,5.5304206291,5.5819410166,5.6495158658,
//	5.5000916593,5.3367546724,5.3308768398,5.1888452730,5.1138188005,
//	5.2152656077,5.1699825419,5.0595489236,5.0674040507,5.0517570835,
//	5.0120681030}

>

channel(#av_m_to_av_m) 
< 
	@channel =   #T2Kplus:	  -:	 mu:	 mu:	#QE:	 #CCQE_numu_MIS

//	@post_smearing_efficiencies = {0.0000000000,1.8542085854,5.6111824772,7.2203718713,8.2217562454,
//	9.0952813526,9.1429754020,8.3805695901,6.8942237669,6.0656063510,
//	5.7811556206,5.6431500772,5.5465535053,5.4880559976,5.7865811866,
//	5.8772688674,6.0596786161,6.2523423490,6.1185305483,5.9598922298,
//	5.9181406426,6.0905031126,6.3927993156,6.4962743505,6.2853642985,
//	5.9752394362,5.9555814925,6.3068707268,6.5033986689,6.4998186349,
//	6.4480452921,6.2482554188,6.0855172373,6.0447488018,6.0335361465,
//	6.3497303728}


>

channel(#v_m_to_v_m_NC) 
< 
	@channel =   #T2Kplus:	  +:	 NOSC_m:	NOSC_m:	#NC:	 #NC_numu
//	@post_smearing_efficiencies = {0.0178641031,0.0751141377,0.1302836054,0.1145549305,0.0818222715,
//	0.0644171884,0.0681742979,0.0732754674,0.0699250281,0.0694835709,
//	0.0690104829,0.0658908473,0.0597284792,0.0493774318,0.0371633333,
//	0.0198950341,0.0047705604,0.0000000000,0.0000000000,0.0005785081,
//	0.0003175876,0.0000000000,0.0000000000,0.0000445240,0.0000244615,
//	0.0000000000,0.0000000000,0.0000029850,0.0000016425,0.0000000000,
//	0.0000000000,0.0000002102,0.0000001143,0.0000000000,0.0000000000,
//	0.0000000159}


>

/***********************************************
************************************************
***                                          ***
***              End NU MODE                 ***
***                                          ***
************************************************
**********************************************/


rule(#rule0)
< 
	@signal = 1.0@#v_m_to_v_m:1.0@#av_m_to_av_m
	@signalerror = 0.05: 0.001
	@background = 1.0@#v_m_to_v_m_NC
	@backgrounderror = 0.10 : 0.0001
	@sys_on_function = "chiSpectrumTilt"  
	@sys_off_function = "chiNoSysSpectrum"
	//@data_flag = 1
	//@data = { 6, 26, 23, 13, 14, 16, 12, 12, 14, 11, 11, 9, 8, 9, 5, 0, 2, 1, 2, 6, 4, 4, 1, 4, 3, 2, 0, 1}
>
