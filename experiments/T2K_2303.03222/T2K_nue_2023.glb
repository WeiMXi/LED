%!GLoBES
$version="3.2.13"


/*************************************************
**************************************************
*** Prepared by Hai-xing Lin(15 August 2023)  ***
***              T2K-CURRENT                   ***  
*** see ref: 2303.03222				           ***
***          nue->nue and anue->anue           ***
*** 		   flux from 		       ***
***   http://cds.cern.ch/record/2695231/plots  ***
**************************************************
**************************************************/


nuflux(#T2Kplus)
<
	@flux_file = "../experiments/T2K_2303.03222/flux/T2K_LHC_mode_2018_flux.dat"
	@time = 12.0
	@power = 0.75 /* MW */
	@norm = 0.033358 /* for 14.7x10^20 POT*/
>

nuflux(#T2Kminus)
<
	@flux_file = "../experiments/T2K_2303.03222/flux/T2K_RHC_mode_2018_flux.dat"
	@time = 12.0 
	@power = 0.75 /* MW */
	@norm = 0.037215 /* RHC mode worked with 16.4x10^20 POT*/
> 
//Flux part is not corresponding to new data
$profiletype = 3
$densitytab = {2.8}
$lengthtab = {295}


$target_mass = 22.5 /* kt */

$emin = 0.1
$emax = 1.25
$bins = 23

 
$sampling_points = 120 
$sampling_min = 0.2
$sampling_max = 3.0


$filter_state = 0
$filter_value = 0.05


cross(#NC) < @cross_file = "../experiments/T2K_2303.03222/xsec/waterGENIE3_NC.dat" >
cross(#QE) < @cross_file = "../experiments/T2K_2303.03222/xsec/waterGENIE3_CCQE.dat" >
cross(#CC) < @cross_file = "../experiments/T2K_2303.03222/xsec/waterGENIE3_CCnonQE.dat" >


energy(#CCQE_nue)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>


energy(#NC_nue)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>

energy(#CCQE_anue)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>

energy(#CCQE_anueWrong)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>


energy(#NC_anue)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>


energy(#CCnonQE_nue)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>


energy(#NC_nuenonQE)<
	@type = 1
	@sigma_e = {4.0e-3,5.05e-2,8.08e-2}
>



