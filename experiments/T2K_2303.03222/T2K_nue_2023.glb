rule(#rule0)
< 
	@signal = 1.0@#v_m_to_v_e:1.0@#v_e_to_v_e
	//@signalerror = 0.05: 0.0001
	@background =1.0@#v_m_to_v_m_NC
	//@backgrounderror = 0.10 : 0.0001
	//@sys_on_function = "chiSpectrumTilt"  
	@sys_on_function = "ChiT2K"  
	@sys_on_errors = {0.05, 0.0001, 0.10, 0.0001} 
	@sys_off_function = "chiNoSysSpectrum"
	@data_flag = 1
	@data = {2,5,3,4,1,9,6,8,11,4,
			 4,9,4,9,4,4,4,1,0,0,
			 1,1,0}
 >



rule(#rule1)
< 
	@signal = 1.0@#v_m_to_v_eRHC:1.0@#v_e_to_v_eRHC:1.0@#av_m_to_av_eRHC:1.0@#av_e_to_av_eRHC
	//@signalerror = 0.05: 0.0001
	@background =1.0@#v_m_to_v_m_NCRHC
	//@backgrounderror = 0.10 : 0.0001
	//@sys_on_function = "chiSpectrumTilt"  
	@sys_on_function = "ChiT2K"  
